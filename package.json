{
  "name": "macos-work-tracker",
  "version": "0.0.1",
  "description": "Automatic work time tracker for macOS - tracks screen lock/unlock events",
  "type": "module",
  "scripts": {
    "start": "bun run src/daemon.ts",
    "cli": "bun run src/cli.ts",
    "build": "bun build --compile --outfile=work-tracker src/cli.ts && bun build --compile --outfile=work-tracker-daemon src/daemon.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "work-tracker",
    "time-tracking",
    "macos",
    "productivity",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cassmtnr/macos-active-time.git"
  },
  "bugs": {
    "url": "https://github.com/cassmtnr/macos-active-time/issues"
  },
  "homepage": "https://github.com/cassmtnr/macos-active-time#readme",
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bun": "latest",
    "eslint": "^9.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}